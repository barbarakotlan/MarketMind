# ===========================================
# MarketMind Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ===========================================

# ===========================================
# API KEYS - Get from respective providers
# ===========================================

# Alpha Vantage API Key (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=_

# NewsAPI Key (https://newsapi.org/account)
NEWS_API_KEY=_

# Finnhub API Key (https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_key_here

# OpenBB (optional - if using OpenBB integration)
# OPENBB_API_KEY=your_openbb_key_here

# EdgarTools / SEC EDGAR identity (optional - enables enhanced SEC filings and section parsing)
# Required for EdgarTools access if installed. Format can be "Name email@domain.com" or just "email@domain.com".
# EDGAR_IDENTITY=analyst@yourdomain.com

# Akshare international research (optional - enables HK/CN search, fundamentals, and MarketMindAI context)
# Keep false by default so US-only deployments do not depend on scraper-backed international data.
AKSHARE_ENABLED=false

# Sentiment intelligence (optional - enables FinBERT tone scoring for internal news, filings, and AI context)
# Keep false by default so backend startup does not depend on downloaded model weights.
SENTIMENT_INTELLIGENCE_ENABLED=false
# SENTIMENT_MODEL_ID=ProsusAI/finbert
# SENTIMENT_BATCH_SIZE=8
# SENTIMENT_CACHE_MAX_ENTRIES=5000

# MarketMind research retrieval (optional - enables SentenceTransformers + Qdrant evidence retrieval for MarketMindAI)
# Keep false by default so MarketMindAI continues using context-only mode unless retrieval is explicitly enabled.
RESEARCH_RETRIEVAL_ENABLED=false
# QDRANT_URL=:memory:
# QDRANT_API_KEY=
# QDRANT_GLOBAL_COLLECTION=marketmind_global_research_v1
# QDRANT_USER_COLLECTION=marketmind_user_research_v1
# RETRIEVAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# RETRIEVAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RETRIEVAL_TOP_K=12
# RETRIEVAL_RERANK_K=8

# ===========================================
# Backend Configuration
# ===========================================

# Flask Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=_

# Environment (development/production)
FLASK_ENV=development

# Clerk JWT Verification (backend)
# Required in production. Development may fall back only for trusted https Clerk dev issuers.
# CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
# CLERK_ISSUER=https://your-clerk-domain
# Optional audience check for session token verification
# CLERK_AUDIENCE=your-api-audience

# Allowed CORS origins (comma-separated for production)
# Development:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Legacy user-data seeding from shared JSON files (recommended: false)
ALLOW_LEGACY_USER_DATA_SEED=false

# User-state persistence mode:
# json     = existing JSON files only
# dual     = Postgres primary, JSON mirror on writes
# postgres = Postgres only
PERSISTENCE_MODE=json

# API CSP policy (optional override)
# API_CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none';

# ===========================================
# Frontend Configuration
# ===========================================

# Backend API URL
REACT_APP_API_URL=http://localhost:5001

# Clerk Frontend Publishable Key
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ===========================================
# Security Configuration
# ===========================================

# Enable HTTPS redirect in production (true/false)
FORCE_HTTPS=false

# Rate limiting (requests per minute)
RATE_LIMIT_LIGHT=10/minute
RATE_LIMIT_STANDARD=20/minute
RATE_LIMIT_HEAVY=2/minute
RATE_LIMIT_WRITE=5/minute

# ===========================================
# MarketMind Public API (private beta)
# ===========================================

# Feature flags
PUBLIC_API_ENABLED=false
PUBLIC_API_DOCS_ENABLED=false

# Hash pepper used to hash MarketMind developer API keys
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PUBLIC_API_KEY_HASH_PEPPER=

# Shared limiter storage backend (required when public API is enabled)
# Example Redis URL:
# PUBLIC_API_RATE_LIMIT_STORAGE_URL=redis://localhost:6379/2

# Public API response cache backend (optional local fallback is in-memory)
# Example Redis URL:
# PUBLIC_API_CACHE_URL=redis://localhost:6379/3

# Private beta defaults
PUBLIC_API_DEFAULT_PER_MINUTE_LIMIT=30/minute
PUBLIC_API_DEFAULT_PER_HOUR_LIMIT=500/hour
PUBLIC_API_DEFAULT_DAILY_QUOTA=2500

# Optional extra protection
# PUBLIC_API_GLOBAL_EMERGENCY_LIMIT=5000/hour
# PUBLIC_API_FALLBACK_IP_LIMIT=120/hour

# ===========================================
# Database (required for dual/postgres persistence)
# ===========================================

# Example local SQLite URL for testing:
# DATABASE_URL=sqlite:///marketmind.db
#
# Example Supabase/Postgres URL:
# DATABASE_URL=postgresql+psycopg://postgres:password@db.your-project.supabase.co:5432/postgres

# ===========================================
# OpenRouter (AI memo generation)
# ===========================================
# OPENROUTER_API_KEY=sk-or-your-openrouter-key
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_SITE_URL=https://your-app.example.com
# OPENROUTER_APP_NAME=MarketMind

# ===========================================
# Portfolio Intelligence
# ===========================================
# Annualized risk-free rate used in paper-portfolio optimization
PORTFOLIO_OPTIMIZATION_RISK_FREE_RATE=0.02

# Black-Litterman market risk aversion coefficient
PORTFOLIO_OPTIMIZATION_RISK_AVERSION=2.5
