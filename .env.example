# ===========================================
# MarketMind Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ===========================================

# ===========================================
# API KEYS - Get from respective providers
# ===========================================

# Alpha Vantage API Key (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=_

# NewsAPI Key (https://newsapi.org/account)
NEWS_API_KEY=_

# Finnhub API Key (https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_key_here

# OpenBB (optional - if using OpenBB integration)
# OPENBB_API_KEY=your_openbb_key_here

# ===========================================
# Backend Configuration
# ===========================================

# Flask Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=_

# Environment (development/production)
FLASK_ENV=development

# Clerk JWT Verification (backend)
# Optional if token includes issuer and your backend can reach issuer/.well-known/jwks.json
# CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
# Optional audience check for session token verification
# CLERK_AUDIENCE=your-api-audience

# Allowed CORS origins (comma-separated for production)
# Development:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Legacy user-data seeding from shared JSON files (recommended: false)
ALLOW_LEGACY_USER_DATA_SEED=false

# User-state persistence mode:
# json     = existing JSON files only
# dual     = Postgres primary, JSON mirror on writes
# postgres = Postgres only
PERSISTENCE_MODE=json

# API CSP policy (optional override)
# API_CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none';

# ===========================================
# Frontend Configuration
# ===========================================

# Backend API URL
REACT_APP_API_URL=http://localhost:5001

# Clerk Frontend Publishable Key
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ===========================================
# Security Configuration
# ===========================================

# Enable HTTPS redirect in production (true/false)
FORCE_HTTPS=false

# Rate limiting (requests per minute)
RATE_LIMIT_LIGHT=10/minute
RATE_LIMIT_STANDARD=20/minute
RATE_LIMIT_HEAVY=2/minute
RATE_LIMIT_WRITE=5/minute

# ===========================================
# Database (required for dual/postgres persistence)
# ===========================================

# Example local SQLite URL for testing:
# DATABASE_URL=sqlite:///marketmind.db
#
# Example Supabase/Postgres URL:
# DATABASE_URL=postgresql+psycopg://postgres:password@db.your-project.supabase.co:5432/postgres
