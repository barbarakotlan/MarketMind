# ===========================================
# Frontend Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ===========================================

# Backend API URL - Change for production
VITE_API_URL=http://localhost:5001

# Authentication mode: clerk or local.
# local works only in development and must match the backend AUTH_MODE.
VITE_AUTH_MODE=clerk
# VITE_LOCAL_AUTH_USER_ID=local_development_user
# VITE_LOCAL_AUTH_TOKEN=marketmind-local-development

# Clerk Frontend Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ===========================================
# Optional: Feature Flags
# ===========================================

# Enable/disable certain features
# VITE_ENABLE_DEBUG=false
# VITE_ANALYTICS_ID=
